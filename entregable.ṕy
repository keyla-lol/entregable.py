# Student Management System

students = []

# ADD
def add_student():
    id = input("ID: ")
    name = input("Name: ")
    age = int(input("Age: "))
    course = input("Course: ")
    status = input("Status (active/inactive): ")

    student = {
        "id": id,
        "name": name,
        "age": age,
        "course": course,
        "status": status,
    }

    students.append(student)
    print("Student added successfully")


# SHOW
def show_students():
    if len(students) == 0:
        print("No students registered")
    else:
        for s in students:
            print(f"{s['id']} | {s['name']} | {s['age']} | {s['course']} | {s['status']}")


# SEARCH
def search_student():
    id = input("Enter ID: ")
    for s in students:
        if s["id"] == id:
            print("Student found:", s)
            return
    print("Student not found")


# UPDATE
def update_student():
    id = input("Enter ID to update: ")
    for s in students:
        if s["id"] == id:
            s["name"] = input("New name: ")
            s["age"] = int(input("New age: "))
            s["course"] = input("New course: ")
            s["status"] = input("New status: ")
            print("Student updated")
            return
    print("Student not found")


# DELETE
def delete_student():
    id = input("Enter ID to delete: ")
    for s in students:
        if s["id"] == id:
            students.remove(s)
            print("Student deleted")
            return
    print("Student not found")


# MENU
while True:
    print("\n--- MENU ---")
    print("1. Add student")
    print("2. Show students")
    print("3. Search student")
    print("4. Update student")
    print("5. Delete student")
    print("6. Exit")

    option = input("Choose an option: ")

    if option == "1":
        add_student()
    elif option == "2":
        show_students()
    elif option == "3":
        search_student()
    elif option == "4":
        update_student()
    elif option == "5":
        delete_student()
    elif option == "6":
        print("Goodbye!")
        break
    else:
        print("Invalid option")
        
            
